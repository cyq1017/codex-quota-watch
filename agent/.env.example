# Required if you expose the Mac agent on LAN. Use at least 24 URL-safe random characters.
WATCH_TOKEN=change-me-to-a-long-random-token

# Default to Mac-only loopback. For iPhone/Watch testing on the same Wi-Fi,
# change this to 0.0.0.0 and keep WATCH_TOKEN set to a strong random value.
AGENT_HOST=127.0.0.1
AGENT_PORT=8787
CACHE_TTL_SECONDS=60

CODEX_HOME=~/.codex

# Codex: v0.2 defaults to official codex app-server JSON-RPC:
# account/rateLimits/read. Disable only if you want a custom command/URL.
CODEX_APP_SERVER_ENABLED=true
CODEX_BINARY=codex
CODEX_APP_SERVER_TIMEOUT_SECONDS=12
QUOTA_PROVIDER_TIMEOUT_SECONDS=16
QUOTA_CACHE_MAX_AGE_SECONDS=1800
# CODEX_QUOTA_CACHE_PATH=~/.cache/codex-quota-watch/codex.json

# Optional override. Command must print JSON with remaining_percent/used_percent/reset_at/reset_in/window.
# CODEX_QUOTA_COMMAND=codex-quota-app-server
# CODEX_QUOTA_URL=http://127.0.0.1:9999/codex-quota
# CODEX_QUOTA_BEARER_TOKEN=

# Optional org/API dashboards only, not personal app subscription quota.
# OPENAI_ADMIN_KEY=

MAX_FILES_TO_SCAN=400
