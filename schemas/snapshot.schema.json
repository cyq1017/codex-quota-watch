{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cyq1017/codex-quota-watch/schemas/snapshot.schema.json",
  "title": "Codex Quota Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "stale",
    "providers"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "stale": {
      "type": "boolean"
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codex"
      ],
      "properties": {
        "codex": {
          "$ref": "#/$defs/providerSnapshot"
        }
      }
    }
  },
  "$defs": {
    "providerSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quota",
        "today",
        "hourly"
      ],
      "properties": {
        "quota": {
          "$ref": "#/$defs/quota"
        },
        "today": {
          "$ref": "#/$defs/tokenStats"
        },
        "hourly": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hourBucket"
          }
        }
      }
    },
    "quota": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "remaining_percent",
        "used_percent",
        "reset_at",
        "reset_in",
        "window",
        "source",
        "updated_at",
        "status",
        "error",
        "buckets"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "remaining_percent": {
          "type": [
            "number",
            "null"
          ]
        },
        "used_percent": {
          "type": [
            "number",
            "null"
          ]
        },
        "reset_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "reset_in": {
          "type": [
            "string",
            "null"
          ]
        },
        "window": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "enum": [
            "ok",
            "partial",
            "error",
            "not_configured"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "buckets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/quotaBucket"
          }
        }
      }
    },
    "quotaBucket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "remaining_percent",
        "used_percent",
        "reset_at",
        "reset_in",
        "window",
        "status"
      ],
      "properties": {
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "remaining_percent": {
          "type": [
            "number",
            "null"
          ]
        },
        "used_percent": {
          "type": [
            "number",
            "null"
          ]
        },
        "reset_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "reset_in": {
          "type": [
            "string",
            "null"
          ]
        },
        "window": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "enum": [
            "ok",
            "partial",
            "error",
            "not_configured"
          ]
        }
      }
    },
    "tokenStats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "cache_tokens",
        "total_tokens"
      ],
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cache_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "hourBucket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hour",
        "input_tokens",
        "output_tokens",
        "cache_tokens",
        "total_tokens"
      ],
      "properties": {
        "hour": {
          "type": "integer",
          "minimum": 0,
          "maximum": 23
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cache_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
